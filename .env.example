# PostgreSQL Database Configuration (Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Admin Panel Configuration
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=your_admin_password
ADMIN_COOKIE_SECRET=your_cookie_secret_here
ADMIN_PORT=3001

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# File Upload Configuration
UPLOAD_DIR=./public/uploads
MAX_FILE_SIZE=5242880
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/jpg
ALLOWED_FILE_TYPES=application/pdf,image/jpeg,image/png,image/webp

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# SMS OTP
SMS_ENABLED=false
SMS_API_KEY=your_sms_api_key_here

# Environment
NODE_ENV=production

# CORS (add your Vercel domain)
ALLOWED_ORIGINS=https://your-app.vercel.app
